# Server-side Kaggle auth. These must never be exposed to browser JavaScript.
KAGGLE_API_TOKEN=

# Legacy Kaggle API credentials are still supported.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional aliases if you are experimenting with Kaggle OAuth access tokens.
KAGGLE_BEARER_TOKEN=
KAGGLE_ACCESS_TOKEN=

# Local replay persistence.
CABT_DATA_DIR=.data

# Required for browser-driven imports/Kaggle access on a public deployment.
CABT_ADMIN_TOKEN=

# Development only. Leave false for public deployments.
CABT_ALLOW_PUBLIC_IMPORTS=false
