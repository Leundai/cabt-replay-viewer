# Server-side Kaggle auth. These must never be exposed to browser JavaScript.
KAGGLE_API_TOKEN=

# Legacy Kaggle API credentials are still supported.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional aliases if you are experimenting with Kaggle OAuth access tokens.
KAGGLE_BEARER_TOKEN=
KAGGLE_ACCESS_TOKEN=

# Local replay persistence.
CABT_DATA_DIR=.data
CABT_MAX_REPLAY_BYTES=26214400
CABT_MAX_STORED_REPLAYS=500

# Required for Kaggle access and backend replay uploads on a public deployment.
CABT_ADMIN_TOKEN=

# Development only. Allows unauthenticated backend replay uploads, but Kaggle
# endpoints remain admin-only. Leave false for public deployments.
CABT_ALLOW_PUBLIC_IMPORTS=false
