# Server-side Kaggle auth. These must never be exposed to browser JavaScript.
KAGGLE_API_TOKEN=

# Legacy Kaggle API credentials are still supported.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional aliases if you are experimenting with Kaggle OAuth access tokens.
KAGGLE_BEARER_TOKEN=
KAGGLE_ACCESS_TOKEN=

# Kaggle leaderboard cache. Public reads use this cache; Kaggle refreshes are
# capped by the server-side TTL unless an admin explicitly forces a refresh.
KAGGLE_DEFAULT_COMPETITION=pokemon-tcg-ai-battle
KAGGLE_API_BASE_URL=https://api.kaggle.com
KAGGLE_LEADERBOARD_CACHE_SECONDS=1800
KAGGLE_LEADERBOARD_PAGE_SIZE=50
KAGGLE_LEADERBOARD_TEAM_SUBMISSION_LIMIT=12
KAGGLE_LEADERBOARD_SUBMISSIONS_PER_TEAM=2
KAGGLE_LEADERBOARD_EPISODES_PER_SUBMISSION=2

# Local replay persistence.
CABT_DATA_DIR=.data
CABT_MAX_REPLAY_BYTES=26214400
CABT_MAX_STORED_REPLAYS=500

# Required for Kaggle access and backend replay uploads on a public deployment.
CABT_ADMIN_TOKEN=

# Development only. Allows unauthenticated backend replay uploads, but Kaggle
# endpoints remain admin-only. Leave false for public deployments.
CABT_ALLOW_PUBLIC_IMPORTS=false
